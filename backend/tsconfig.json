{
  "compilerOptions": {
    // "module": "ESNext", //DEV
    "module": "CommonJS", //PRD
    "target": "ES2020",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src", //PRD
  },
  "include": [
    "src/**/*"
  ] //PRD
}